<Window x:Class="Converter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Converter.MVVM.ViewModel"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="450"
        Width="250"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <vm:FlagConverter x:Key="FlagConverter"/>
    </Window.Resources>

    <Border Background="#272537" CornerRadius="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="310"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Name="ToolBar" Grid.Row="0" Background="Transparent" MouseDown="ToolBar_MouseDown">
                <Polygon Fill="White" Opacity="0.8"
                         Points="57,0, 65,7, 189,7, 197,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="7">
                    <Image Name="Minimize" Height="15" Width="15" Margin="0,1,5,3"
                           MouseDown="Minimize_MouseDown">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Source" Value="Images/minimaze.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=Minimize}" Value="true">
                                        <Setter Property="Source" Value="Images/minimaze_active.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                    <Image Name="CloseWindow" Height="13" Width="13" Margin="1,1,3,1"
                           MouseDown="CloseWindow_MouseDown">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Source" Value="Images/x.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=CloseWindow}" Value="true">
                                        <Setter Property="Source" Value="Images/x_active.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </StackPanel>
            </Grid>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <emoji:TextBlock Text="{Binding RateDisplay}"
                           Foreground="#CFCFCF" FontSize="14"
                           Margin="25,3,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Top"/>

                <!-- First currency input -->
                <TextBox Text="{Binding FirstAmount, UpdateSourceTrigger=PropertyChanged}"
                         Margin="25,25,0,0"
                         VerticalAlignment="Top" HorizontalAlignment="Left"
                         PreviewTextInput="CurrencyBox_PreviewTextInput"
                         LostFocus="CurrencyBox_LostFocus"
                         Style="{StaticResource ModernTextBox}"/>

                <!-- First currency dropdown button -->
                <Border Height="25" Width="75"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="27,33,0,0" CornerRadius="2">
                    <Button Command="{Binding ToggleFirstDropdownCommand}"
                            Style="{StaticResource ComboBoxButton}">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="{Binding FirstCurrency, Converter={StaticResource FlagConverter}}"
                                       Foreground="#CFCFCF" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Image Width="15" Margin="5,0,0,0"
                                   Style="{StaticResource ArrowDownImage}"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- First currency dropdown list -->
                <Border Visibility="{Binding IsFirstDropdownOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="10"
                        Background="#272537" BorderBrush="#FF40454E" BorderThickness="1"
                        CornerRadius="5"
                        Margin="27,60,130,0"
                        VerticalAlignment="Top"
                        MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Currencies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ModernButton}"
                                            Command="{Binding DataContext.SelectFirstCurrencyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <emoji:TextBlock Text="{Binding Converter={StaticResource FlagConverter}}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Arrow indicator -->
                <Border CornerRadius="12" Background="#353340"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                        Margin="52,82,52,52" Width="27" Height="26">
                    <Image Height="19" Width="20">
                        <Image.Style>
                            <Style TargetType="{x:Type Image}">
                                <Setter Property="Source" Value="Images/Down.png"/>
                            </Style>
                        </Image.Style>
                    </Image>
                </Border>

                <!-- Second currency input -->
                <TextBox Text="{Binding SecondAmount, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Top" HorizontalAlignment="Left"
                         Margin="25,128,0,0"
                         PreviewTextInput="CurrencyBox_PreviewTextInput"
                         LostFocus="CurrencyBox_LostFocus"
                         Style="{StaticResource ModernTextBox}"/>

                <!-- Second currency dropdown button -->
                <Border Height="25" Width="75"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="27,136,0,0" CornerRadius="2">
                    <Button Command="{Binding ToggleSecondDropdownCommand}"
                            Style="{StaticResource ComboBoxButton}">
                        <StackPanel Orientation="Horizontal">
                            <emoji:TextBlock Text="{Binding SecondCurrency, Converter={StaticResource FlagConverter}}"
                                       Foreground="#CFCFCF" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Image Width="15" Margin="5,0,0,0"
                                   Style="{StaticResource ArrowDownImage}"/>
                        </StackPanel>
                    </Button>
                </Border>

                <!-- Second currency dropdown list -->
                <Border Visibility="{Binding IsSecondDropdownOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="10"
                        Background="#272537" BorderBrush="#FF40454E" BorderThickness="1"
                        CornerRadius="5"
                        Margin="27,160,130,0"
                        VerticalAlignment="Top"
                        MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Currencies}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ModernButton}"
                                            Command="{Binding DataContext.SelectSecondCurrencyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <emoji:TextBlock Text="{Binding Converter={StaticResource FlagConverter}}"/>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Bottom decoration -->
            <Grid Grid.Row="2">
                <Border>
                    <Grid VerticalAlignment="Bottom">
                        <Polygon Fill="White" Opacity="0.8"
                                 Points="57,7, 65,0, 189,0, 197,7"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
